# ── wp-content-mcp — configuración ──────────────────────────────────────────
# Motor de contenido WordPress (páginas + blog). 100% público: NO necesita
# credenciales. Por defecto configurado para Solidker.

# Base del WordPress (sin barra final)
WP_BASE_URL=https://www.solidker.com

# Identidad de marca
BRAND_NAME=Solidker
BRAND_SLUG=solidker

# Slugs de páginas a ocultar en `paginas` (legales, índice de blog), separados por coma
HIDE_PAGES=privacy-policy,aviso-legal,blog

# Comportamiento
DEFAULT_LIMIT=10
MAX_LIMIT=50
