# ── woo-catalog-mcp — configuración por marca ───────────────────────────────
# Copia este archivo a .env y rellena con datos REALES. .env está gitignored.
# Para clonar a otra tienda (p.ej. solidker), copia a .env.solidker y arranca
# con: ENV_FILE=.env.solidker node src/index.js

# Base del WordPress (sin barra final)
WP_BASE_URL=https://www.adrihosan.com

# Credencial server-side (Application Password de WordPress).
# El usuario externo NO necesita esto: vive solo en el servidor y solo se usa
# para LECTURA. Crea una en: WP Admin → Usuarios → tu perfil → Application Passwords.
WP_USERNAME=tu_usuario_wp
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Identidad de marca (rotula las tools y respuestas)
BRAND_NAME=Adrihosan
BRAND_SLUG=adrihosan

# Comportamiento
DEFAULT_LIMIT=5          # nº por defecto en "ultimos_*"
MAX_LIMIT=20             # tope duro
EXPOSE_STOCK=false       # true para incluir stock_status en los productos
CURRENCY=EUR

# Página general de FAQs (schema FAQPage). La tool `faqs` sin argumentos
# devuelve estas. Dejar vacío si la tienda no tiene página general de FAQs.
FAQ_PAGE_URL=https://www.adrihosan.com/preguntas-frecuentes-adrihosan/
