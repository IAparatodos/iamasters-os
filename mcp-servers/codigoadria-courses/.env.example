# ── codigoadria-courses-mcp — configuración ─────────────────────────────────
# Copia a .env. Este MCP es 100% público (REST de WordPress): NO necesita
# credenciales. Solo la URL base y la identidad de marca.

# Base del WordPress de cursos (sin barra final)
WP_BASE_URL=https://www.codigoadria.com

# Identidad de marca (rotula tools y respuestas)
BRAND_NAME=Código AdrIA
BRAND_SLUG=codigoadria

# Una categoría se considera "un curso" si su nombre empieza por este prefijo.
COURSE_CATEGORY_PREFIX=Curso

# Comportamiento
DEFAULT_LIMIT=10         # nº por defecto en listados
MAX_LIMIT=50             # tope duro
